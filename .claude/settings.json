{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "mcp__mcp-gateway-sourcegraph",
      "mcp__mcp-gateway-gdrive",
      "mcp__mcp-gateway-figma",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch --show-current)",
      "Bash(jq empty *)",
      "Bash(bash -n *)",
      "Bash(zsh -n *)",
      "Bash(shfmt -d *)",
      "Bash(stylua --check *)",
      "Bash(shellcheck *)"
    ],
    "deny": [
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(chown *)"
    ]
  },
  "model": "claude-sonnet-5",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/format-config.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/compact-context.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/statusline.sh\"",
    "refreshInterval": 10,
    "hideVimModeIndicator": true
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/subagent-statusline.sh\""
  },
  "spinnerTipsEnabled": false,
  "awaySummaryEnabled": true,
  "showClearContextOnPlanAccept": true,
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "theme": "dark",
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "terminal_bell",
  "autoCompactEnabled": true,
  "fileCheckpointingEnabled": true,
  "showTurnDuration": true,
  "showMessageTimestamps": true,
  "terminalProgressBarEnabled": true,
  "todoFeatureEnabled": true
}
